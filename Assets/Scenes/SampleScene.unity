  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u043B\u043D\u0443\u044E
    \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0443 \u0438 \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u044E
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430, \u0447\u0442\u043E\u0431\u044B
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0435\u0433\u043E \u0441\u0435\u043D\u0441\u043E\u0440\u043E\u0432
    \u0438 \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0443 \u0434\u0430\u043D\u043D\u044B\u0445
    \u043D\u0430 \u043E\u0440\u0431\u0438\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u0430\u043D\u0446\u0438\u044E. \u0412\u044B\u043F\u043E\u043B\u043D\u0438
    \u0432\u0441\u0435 \u044D\u0442\u0430\u043F\u044B \u043A\u043E\u043D\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u0438:
    \u043E\u0442 \u043A\u0430\u043B\u0438\u0431\u0440\u043E\u0432\u043A\u0438 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F \u0434\u043E
    \u0442\u0435\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u0441\u0432\u044F\u0437\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043C\u0438\u0441\u0441\u0438\u044F \u043F\u0440\u043E\u0448\u043B\u0430
    \u0431\u0435\u0437 \u0441\u0431\u043E\u0435\u0432."
